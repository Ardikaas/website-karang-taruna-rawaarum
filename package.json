{
  "name": "karangtaruna-rawaarum",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo - Website Karang Taruna Kelurahan Rawa Arum, Kec. Grogol, Kota Cilegon",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently --names SERVER,CLIENT --prefix-colors blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "build:client": "npm run build --workspace=client",
    "start:server": "npm run start --workspace=server",
    "lint:client": "npm run lint --workspace=client",
    "install:all": "npm install",
    "prepare": "husky"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.1",
    "oxlint": "^1.75.0",
    "prettier": "^3.9.6"
  },
  "lint-staged": {
    "*.{js,jsx,json,css,md}": "prettier --write",
    "client/**/*.{js,jsx}": "npx oxlint",
    "server/**/*.js": "npx oxlint"
  }
}
